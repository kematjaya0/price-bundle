{
    "name": "kematjaya/price-bundle",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Nur Hidayatullah",
            "email": "kematjaya0@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/http-kernel": "^7.0|^8.0",
        "symfony/dependency-injection": "^7.0|^8.0",
        "symfony/config": "^7.0|^8.0",
        "symfony/form": "^7.0|^8.0",
        "twig/twig": "^3.14|^4.0",
        "symfony/intl": "^7.0|^8.0",
        "symfony/translation": "^7.0|^8.0",
        "symfony/event-dispatcher": "^7.0|^8.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Kematjaya\\PriceBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kematjaya\\PriceBundle\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^11.0",
        "symfony/var-dumper": "^7.0|^8.0",
        "symfony/framework-bundle": "^7.0|^8.0",
        "symfony/browser-kit": "^7.0|^8.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "test": "phpunit"
    }
}
